{
    "name": "leonrenkema/nmea-parser",
    "description": "NMEA0183 parser",
    "version": "0.0.1",
    "type": "library",
    "require-dev": {
        "phpunit/phpunit": "^13.1",
        "phpstan/phpstan": "^2.1",
        "laravel/pint": "^1.29"
    },
    "autoload": {
        "psr-4": {
            "Leonrenkema\\NmeaParser\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Leon Renkema"
        }
    ],
    "require": {
        "php": ">8.4"
    },
    "scripts": {
        "pint": "vendor/bin/pint",
        "phpstan": "vendor/bin/phpstan --level=9 analyse src tests"
    }
}
